# ── OpenAI ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000

# ── Perplexity ──
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar-pro

# ── Supabase ──
# Берётся из настроек проекта на supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role (секретный — только на бэкенде!)
SUPABASE_ANON_KEY=eyJ...      # anon key

# ── Storage ──
SUPABASE_BUCKET_FILES=project-files
SUPABASE_BUCKET_EXPORTS=exports

# ── App ──
# Для Railway добавить домен фронтенда после деплоя
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
MAX_FILE_SIZE_MB=20
MAX_IMAGE_SIZE_MB=10
